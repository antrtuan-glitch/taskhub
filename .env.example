# Supabase - copy file này thành .env và điền giá trị thật
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# VAPID Public Key cho Web Push (tạo trên Supabase Dashboard → Edge Functions → Secrets)
# Sau khi tạo VAPID key pair, điền public key vào đây
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
